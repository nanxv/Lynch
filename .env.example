# Copy to .env and fill in your Telegram bot credentials.
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Each recipient messages the bot once, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find each chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: multiple recipients (comma-separated). Wife can be added here.
# TELEGRAM_CHAT_IDS=123456789,987654321

# Expo Push (mobile app). Optional access token for higher rate limits.
# EXPO_ACCESS_TOKEN=

# API bind (local dev)
# API_HOST=0.0.0.0
# API_PORT=8000

# ── 彼得·林奇分析 Agent（后台自动化流水线）─────────────────────────
# 本地测试时可放这里；正式运行用 GitHub Secrets（脚本一律从系统环境变量读取，.env 可选）。
# 到 https://aistudio.google.com/apikey 生成 Gemini key
GEMINI_API_KEY=
# 三层漏斗模型（免费档稳定版）
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# GEMINI_PRO_MODEL=gemini-2.5-pro
# GEMINI_MODEL=gemini-2.5-flash
# LAYER3_FLASH_TOP_N=10
# GEMINI_FLASH_INTERVAL_SEC=4.5
# GEMINI_PRO_INTERVAL_SEC=32

# 邮件通知（SMTP）。未配置齐全则只打印不发信。
# Gmail 示例：需先开两步验证，再到「应用专用密码」生成 16 位授权码填入 SMTP_PASSWORD。
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_sender@gmail.com
SMTP_PASSWORD=
RECEIVER_EMAIL=your_inbox@example.com

# ── 双层漏斗 / 数据源 / 成本控制（均可选，有默认值）──────────────
# 数据源：yahoo / fmp（需 FMP_API_KEY）
# DATA_PROVIDER=fmp
# FMP_API_KEY=your_fmp_key
# Starter 付费档：FMP_DAILY_QUOTA=0（禁用日封顶）· FMP_REQUEST_INTERVAL=0.21（≈286次/分钟）
# 全市场海选来源（默认 us_sbi ≈ SBI 可直购美股，约 3500+）：
#   us_sbi / us / us_midcap / sp500 / nasdaq100 / jpx
# UNIVERSE_SOURCES=us_sbi
# SBI 池：市值门槛（美元）与交易所
# SBI_UNIVERSE_MIN_MARKET_CAP=300000000
# SBI_UNIVERSE_EXCHANGES=NYSE,NASDAQ,AMEX
# SBI_UNIVERSE_LIMIT=10000
# 全美股(us 源)每次随机无放回抽样数量（防封 + 一周轮动扫全市场）
# US_MARKET_SAMPLE_SIZE=500
# 单次海选池上限（0=不截断；务必保持 0 才能扫全量 SBI 池）
# MAX_UNIVERSE_SCAN=0
# 第一层漏斗并发（FMP 建议 ≤8，避免 burst 触发 429）
# SCAN_WORKERS=8
# 第一层漏斗阈值（可选）
# FUNNEL_MAX_PEG=1.5
# FUNNEL_MIN_NETCASH_RATIO=0.30
# FUNNEL_MAX_DEBT_RATIO=0.33   # 长期负债/股东权益；金融股豁免
# 第二层 AI（monthly 兼容）：默认 30；周报已改三层漏斗，不受此截断 Flash 扫射
# MAX_AI_ANALYSIS_COUNT=30
# Layer 3：held + Flash Top N
# LAYER3_FLASH_TOP_N=10
# AI 排序口径：peg(最划算) / net_cash(安全垫最厚)
# AI_SORT_KEY=peg
# 默认市场：US（美股重心）/ ALL / JP
# MARKET=US
